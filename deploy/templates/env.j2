{{ ansible_managed | comment }}
# Runtime env for trading-bot on {{ inventory_hostname }}

# ── Core ──────────────────────────────────────────────────────────────────
NODE_ENV={{ node_env }}
LOG_LEVEL={{ log_level }}
PORT={{ api_port }}

# ── Database / cache ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://{{ pg_user }}:{{ pg_password }}@localhost:5432/{{ pg_database }}
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET={{ jwt_secret }}

# ── Static files (api serves FE in production) ────────────────────────────
FRONTEND_DIST={{ app_dir }}/apps/web/dist

# ── Exchange / prices ─────────────────────────────────────────────────────
EXCHANGE_ID={{ exchange_id }}
TRADING_SYMBOL={{ trading_symbol }}

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_TOKEN={{ telegram_token }}
TELEGRAM_CHANNEL_ID={{ telegram_channel_id }}

# ── Polymarket (empty = simulate) ─────────────────────────────────────────
POLY_PRIVATE_KEY={{ poly_private_key }}
POLY_FUNDER_ADDRESS={{ poly_funder_address }}
POLY_SIGNATURE_TYPE={{ poly_signature_type }}

# ── Observability (optional) ──────────────────────────────────────────────
GRAFANA_OTLP_ENDPOINT={{ grafana_otlp_endpoint }}
GRAFANA_CLOUD_METRICS_URL={{ grafana_cloud_metrics_url }}
GRAFANA_CLOUD_METRICS_USER={{ grafana_cloud_metrics_user }}
GRAFANA_CLOUD_TRACES_URL={{ grafana_cloud_traces_url }}
GRAFANA_CLOUD_LOGS_URL={{ grafana_cloud_logs_url }}
GRAFANA_CLOUD_LOGS_USER={{ grafana_cloud_logs_user }}
GRAFANA_CLOUD_API_KEY={{ grafana_cloud_api_key }}
ANTHROPIC_API_KEY={{ anthropic_api_key }}
VOYAGE_API_KEY={{ voyage_api_key }}
