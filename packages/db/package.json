{
  "name": "@trading-bot/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".":             { "types": "./dist/client.d.ts",  "import": "./dist/client.js" },
    "./migrate":     { "types": "./dist/migrate.d.ts", "import": "./dist/migrate.js" },
    "./migrations":  "./src/migrations/*.sql"
  },
  "scripts": {
    "build":     "tsc && mkdir -p dist/migrations && cp src/migrations/*.sql dist/migrations/",
    "dev":       "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.7.0"
  }
}
