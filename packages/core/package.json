    "@trading-bot/db": "workspace:*",
    "@trading-bot/shared": "workspace:*",
    "ethers": "^5.8.0",
    "grammy": "^1.30.0",
    "ioredis": "^5.10.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0"
