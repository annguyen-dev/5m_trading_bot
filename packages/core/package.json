{
  "name": "@trading-bot/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./CoinConfig": {
      "types": "./dist/CoinConfig.d.ts",
      "import": "./dist/CoinConfig.js"
    },
    "./SignalBus": {
      "types": "./dist/SignalBus.d.ts",
      "import": "./dist/SignalBus.js"
    },
    "./PolymarketService": {
      "types": "./dist/PolymarketService.d.ts",
      "import": "./dist/PolymarketService.js"
    },
    "./orderPlacement": {
      "types": "./dist/orderPlacement.d.ts",
      "import": "./dist/orderPlacement.js"
    },
    "./PolymarketClobExecutor": {
      "types": "./dist/PolymarketClobExecutor.d.ts",
      "import": "./dist/PolymarketClobExecutor.js"
    },
    "./TelegramService": {
      "types": "./dist/TelegramService.d.ts",
      "import": "./dist/TelegramService.js"
    },
    "./telegramChannels": {
      "types": "./dist/telegramChannels.d.ts",
      "import": "./dist/telegramChannels.js"
    },
    "./settings": {
      "types": "./dist/settings.d.ts",
      "import": "./dist/settings.js"
    },
    "./retry": {
      "types": "./dist/retry.d.ts",
      "import": "./dist/retry.js"
    },
    "./logger": {
      "types": "./dist/observability/logger.d.ts",
      "import": "./dist/observability/logger.js"
    }
