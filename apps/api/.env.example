# ── Exchange ──────────────────────────────────────────────────────────────────
EXCHANGE_ID=binance
TRADING_SYMBOL=BTC/USDT

# ── Trading execution ─────────────────────────────────────────────────────────
# TRADING_MODE=paper      → simulate only, no real orders (default)
# TRADING_MODE=live       → place real orders on exchange (requires API keys below)
TRADING_MODE=paper

# Required only when TRADING_MODE=live (Binance USDT-M Futures)
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Size per trade in USDT (default $100)
TRADE_SIZE_USDT=100

# Leverage multiplier (default 1 = no leverage / spot-equivalent)
TRADE_LEVERAGE=1

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voyage AI (embeddings for RAG vector store) ───────────────────────────────
# Get key at: https://dash.voyageai.com
VOYAGE_API_KEY=pa-...

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=123456789:AAF...
TELEGRAM_CHANNEL_ID=-100123456789

# ── Observability — Bot → Grafana Agent (local) ───────────────────────────────
# Bot pushes OTLP to the local Grafana Agent, which forwards to Grafana Cloud.
# Run agent: grafana-agent -config.file=config/grafana-agent.yaml -config.expand-env=true
GRAFANA_OTLP_ENDPOINT=http://localhost:4318

# ── Grafana Cloud credentials (used by Grafana Agent, not the bot directly) ───
# Find these at: grafana.com → your stack → "Details"
GRAFANA_CLOUD_METRICS_URL=https://prometheus-prod-01-eu-west-0.grafana.net/api/prom/push
GRAFANA_CLOUD_METRICS_USER=123456
GRAFANA_CLOUD_TRACES_URL=https://tempo-prod-04-prod-eu-west-2.grafana.net:443
GRAFANA_CLOUD_LOGS_URL=https://logs-prod-eu-west-0.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOGS_USER=234567
GRAFANA_CLOUD_API_KEY=glc_eyJ...

# ── PostgreSQL (run via: docker compose up postgres -d) ──────────────────────
# Local dev: postgres exposed on :5432 from the postgres Docker container.
# Inside Docker: DATABASE_URL is overridden in docker-compose.yaml to use the
# container hostname. Set this in .env for local scripts only.
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading

# ── LanceDB ───────────────────────────────────────────────────────────────────
LANCEDB_PATH=./data/lancedb

# ── News Feed (RSS — no API key required) ────────────────────────────────────
# Leave blank to use built-in defaults (CoinDesk, CoinTelegraph, Decrypt, Bitcoin Magazine)
# Or override with comma-separated RSS URLs:
# NEWS_RSS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss
NEWS_RSS_FEEDS=
NEWS_POLL_INTERVAL_MS=60000

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
