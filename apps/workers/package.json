{
  "name": "@trading-bot/workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":       "SERVICE_NAME=workers tsx watch --include='../../packages/**/*.ts' src/main.ts",
    "start":     "SERVICE_NAME=workers node dist/main.js",
    "build":     "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@trading-bot/core":   "workspace:*",
    "@trading-bot/db":     "workspace:*",
    "@trading-bot/shared": "workspace:*",
    "dotenv":              "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx":         "^4.19.0",
    "typescript":  "^5.7.0"
  }
}
