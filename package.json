{
  "name": "trading-bot",
  "private": true,
  "scripts": {
    "_comment_dev":   "── Local dev ───────────────────────────────────────",
    "dev":            "turbo run dev",
    "dev:api":        "pnpm --filter @trading-bot/api     dev",
    "dev:workers":    "pnpm --filter @trading-bot/workers dev",
    "dev:web":        "pnpm --filter @trading-bot/web     dev",

    "_comment_build": "── Build / lint / clean ───────────────────────────",
    "build":          "turbo run build",
    "typecheck":      "turbo run typecheck",
    "test":           "turbo run test",
    "clean":          "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist .turbo apps/*/.turbo packages/*/.turbo",
    "clean:logs":     "rm -rf logs/*.log",

    "_comment_local_db": "── Local DB ops (Docker postgres if you used it) ─",
    "psql":           "PGPASSWORD=trading psql -h localhost -U trading -d trading",
    "redis-cli":      "redis-cli -h localhost",
    "create-admin":   "pnpm --filter @trading-bot/api create-admin",
    "seed":           "pnpm --filter @trading-bot/api seed-defaults",

    "_comment_audit": "── Security audits ──────────────────────────────",
    "audit:auth":     "bash scripts/audit-auth.sh",

    "_comment_release": "── Deploy (renamed to release:* — pnpm reserves `deploy`) ──",
    "release":           "cd deploy && ansible-playbook deploy.yml",
    "release:bootstrap": "cd deploy && ansible-playbook bootstrap.yml",
    "release:env":       "cd deploy && ansible-playbook deploy.yml --tags env",
    "release:vault":     "cd deploy && ansible-vault edit group_vars/all.yml",
    "release:fix-perms": "cd deploy && ansible-playbook fix-perms.yml",

    "_comment_remote": "── Remote ops — set SERVER_HOST=<ip> or <user@ip>; user prefix is stripped via ${SERVER_HOST##*@} ──",
    "remote:pm2":            "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'pm2 list'",
    "remote:monit":          "ssh -t -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'pm2 monit'",
    "remote:reload":         "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'pm2 reload all'",
    "remote:restart:api":    "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'pm2 restart trading-bot-api'",
    "remote:restart:workers":"ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'pm2 restart trading-bot-workers'",
    "remote:stop:workers":   "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'pm2 stop trading-bot-workers'",
    "remote:start:workers":  "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'pm2 start trading-bot-workers'",
    "remote:logs":           "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'pm2 logs --lines 100'",
    "remote:logs:api":       "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'tail -f /opt/trading-bot/logs/api.log | jq .'",
    "remote:logs:workers":   "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'tail -f /opt/trading-bot/logs/workers.log | jq .'",
    "remote:errors":         "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'tail -n 200 /opt/trading-bot/logs/workers.log | jq \"select(.level >= 40)\"'",
    "remote:health":         "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'curl -s http://localhost:3000/api/health'",
    "remote:psql":           "ssh -t -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'docker exec -it trading-bot-postgres psql -U trading -d trading'",
    "remote:redis-cli":      "ssh -t -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'docker exec -it trading-bot-redis redis-cli'",
    "remote:create-admin":   "ssh -t -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'cd /opt/trading-bot && pnpm --filter @trading-bot/api create-admin'",
    "remote:seed":           "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'cd /opt/trading-bot && pnpm --filter @trading-bot/api seed-defaults'",
    "remote:nginx:reload":   "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'docker exec trading-bot-nginx nginx -s reload'",
    "remote:nginx:logs":     "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'docker logs -f --tail 100 trading-bot-nginx'",
    "remote:nginx:test":     "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@} 'docker exec trading-bot-nginx nginx -t'",
    "remote:ssh":            "ssh -i ~/.ssh/keys/trading-bot-key.pem bot@${SERVER_HOST##*@}"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.11.0"
}
